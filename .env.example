# Copy to .env and fill in. The proxy reads this on startup.
# .env itself is gitignored — never commit secrets.

# Required for any config that uses the frontier backend
# (all_frontier, random, format_check, full_system).
# Get one free at build.nvidia.com.
NVIDIA_API_KEY=nvapi-...

# Override these only if you need to. Defaults are sane.
OLLAMA_URL=http://localhost:11434
NIM_URL=https://integrate.api.nvidia.com/v1
PROXY_PORT=8000

# Routing mode. Each config file under configs/ sets this, so leave default
# unless you're running the proxy standalone.
# ROUTER_MODE=all_local

# Model names. Override per-machine via env (e.g. smaller model on a 16GB MBP).
# LOCAL_MODEL=qwen3-coder-16k
# FRONTIER_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Per-trajectory JSON files land here. Empty string disables persistence.
# TRAJECTORY_DIR=runs/trajectories
